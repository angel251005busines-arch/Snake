<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>🚁 Flappy Drone</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }
        body {
            background: linear-gradient(145deg, #0a2f4a, #06314f);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            touch-action: pan-x pan-y;
        }
        .game-container {
            position: relative;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        canvas {
            display: block;
            border-radius: 16px;
            cursor: pointer;
        }
        .info {
            position: absolute;
            top: 15px;
            left: 0;
            right: 0;
            display: flex;
            justify-content: space-between;
            padding: 0 20px;
            pointer-events: none;
            z-index: 10;
        }
        .score-box, .best-box {
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(4px);
            padding: 8px 16px;
            border-radius: 30px;
            color: white;
            font-weight: bold;
            font-size: 20px;
        }
        .best-box {
            background: rgba(0,0,0,0.5);
        }
        .back-btn {
            position: fixed;
            bottom: 20px;
            left: 20px;
            background: #333;
            border: none;
            color: white;
            padding: 12px 20px;
            border-radius: 30px;
            font-size: 16px;
            cursor: pointer;
            z-index: 100;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-family: inherit;
        }
        .back-btn:active { transform: scale(0.97); }
        
        @media (max-width: 500px) {
            .score-box, .best-box { padding: 6px 12px; font-size: 16px; }
        }
    </style>
</head>
<body>

<a href="index.html" class="back-btn">← Назад</a>

<div class="game-container">
    <div class="info">
        <div class="score-box">🚁 <span id="score">0</span></div>
        <div class="best-box">🏆 <span id="best">0</span></div>
    </div>
    <canvas id="gameCanvas" width="400" height="600"></canvas>
</div>

<script>
    // ========== ИНИЦИАЛИЗАЦИЯ ДЛЯ MAX ==========
    (function initWebApp() {
        if (typeof window.WebApp !== 'undefined') {
            console.log('✅ Запущено в MAX');
            if (typeof window.WebApp.ready === 'function') window.WebApp.ready();
            if (typeof window.WebApp.expand === 'function') window.WebApp.expand();
            
            if (typeof window.WebApp.setBackButtonHandler === 'function') {
                window.WebApp.setBackButtonHandler(() => {
                    window.location.href = 'index.html';
                });
            }
        }
    })();

    // ========== НАСТРОЙКИ ==========
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const scoreSpan = document.getElementById('score');
    const bestSpan = document.getElementById('best');
    
    // Размеры
    const CANVAS_W = 400;
    const CANVAS_H = 600;
    canvas.width = CANVAS_W;
    canvas.height = CANVAS_H;
    
    // Параметры дрона
    const DRONE_SIZE = 28;
    let drone = {
        x: 80,
        y: CANVAS_H / 2,
        velocity: 0,
        gravity: 0.4,
        lift: -7,
        rotation: 0
    };
    
    // Препятствия (трубы -> антенны/мачты)
    let obstacles = [];
    const OBSTACLE_WIDTH = 50;
    const OBSTACLE_GAP = 140;
    const OBSTACLE_SPACING = 220;
    let frame = 0;
    let score = 0;
    let bestScore = localStorage.getItem('drone_best') || 0;
    let gameRunning = true;
    let gameLoopId = null;
    
    bestSpan.textContent = bestScore;
    
    // Изображение дрона (рисуем через canvas, но можно и эмодзи-стиль)
    function drawDrone() {
        ctx.save();
        ctx.translate(drone.x + DRONE_SIZE/2, drone.y + DRONE_SIZE/2);
        // Поворот от скорости
        let targetRot = Math.min(Math.max(drone.velocity * 0.1, -0.5), 0.5);
        drone.rotation = drone.rotation * 0.9 + targetRot * 0.1;
        ctx.rotate(drone.rotation);
        
        // Корпус дрона (квадрат с закруглениями)
        ctx.fillStyle = '#2c3e66';
        ctx.shadowBlur = 0;
        ctx.beginPath();
        ctx.roundRect(-DRONE_SIZE/2, -DRONE_SIZE/2, DRONE_SIZE, DRONE_SIZE, 6);
        ctx.fill();
        
        // Пропеллеры
        ctx.fillStyle = '#aaa';
        ctx.fillRect(-DRONE_SIZE/2 - 8, -4, 8, 8);
        ctx.fillRect(DRONE_SIZE/2, -4, 8, 8);
        ctx.fillRect(-4, -DRONE_SIZE/2 - 8, 8, 8);
        ctx.fillRect(-4, DRONE_SIZE/2, 8, 8);
        
        // Вращающиеся лопасти (анимация)
        let bladeAngle = (Date.now() / 50) % (Math.PI * 2);
        ctx.fillStyle = '#ddd';
        for (let i = 0; i < 4; i++) {
            let angle = bladeAngle + i * Math.PI/2;
            let x = Math.cos(angle) * 14;
            let y = Math.sin(angle) * 14;
            ctx.beginPath();
            ctx.rect(x-2, y-2, 4, 4);
            ctx.fill();
        }
        
        // Окошко камеры
        ctx.fillStyle = '#5bc0ff';
        ctx.beginPath();
        ctx.arc(6, -6, 5, 0, Math.PI*2);
        ctx.fill();
        ctx.fillStyle = '#000';
        ctx.beginPath();
        ctx.arc(6, -6, 2, 0, Math.PI*2);
        ctx.fill();
        
        ctx.restore();
    }
    
    // Препятствия (вышки сотовой связи/антенны)
    function drawObstacle(x, topHeight, bottomY) {
        // Основная мачта
        ctx.fillStyle = '#5a4a3a';
        ctx.fillRect(x, 0, OBSTACLE_WIDTH, topHeight);
        ctx.fillRect(x, bottomY, OBSTACLE_WIDTH, CANVAS_H - bottomY);
        
        // Детали: перекладины
        ctx.fillStyle = '#8b7355';
        for (let y = 30; y < topHeight; y += 40) {
            ctx.fillRect(x - 8, y, OBSTACLE_WIDTH + 16, 6);
        }
        for (let y = bottomY + 30; y < CANVAS_H; y += 40) {
            ctx.fillRect(x - 8, y, OBSTACLE_WIDTH + 16, 6);
        }
        
        // Красные огни на мачтах
        ctx.fillStyle = '#ff3333';
        ctx.beginPath();
        ctx.arc(x + OBSTACLE_WIDTH/2, topHeight - 10, 6, 0, Math.PI*2);
        ctx.fill();
        ctx.beginPath();
        ctx.arc(x + OBSTACLE_WIDTH/2, bottomY + 10, 6, 0, Math.PI*2);
        ctx.fill();
    }
    
    // Добавление препятствия
    function addObstacle() {
        let gapY = Math.random() * (CANVAS_H - OBSTACLE_GAP - 100) + 50;
        obstacles.push({
            x: CANVAS_W,
            topHeight: gapY,
            bottomY: gapY + OBSTACLE_GAP,
            counted: false
        });
    }
    
    // Обновление препятствий
    function updateObstacles() {
        for (let i = 0; i < obstacles.length; i++) {
            obstacles[i].x -= 3;
            
            // Подсчёт очков
            if (!obstacles[i].counted && obstacles[i].x + OBSTACLE_WIDTH < drone.x) {
                obstacles[i].counted = true;
                score++;
                scoreSpan.textContent = score;
                
                // Вибрация при прохождении препятствия
                if (typeof navigator.vibrate === 'function') navigator.vibrate(50);
            }
        }
        obstacles = obstacles.filter(obs => obs.x + OBSTACLE_WIDTH > 0);
    }
    
    // Проверка столкновений
    function checkCollision() {
        // Границы
        if (drone.y <= 0 || drone.y + DRONE_SIZE >= CANVAS_H) return true;
        
        // С препятствиями
        for (let obs of obstacles) {
            if (drone.x + DRONE_SIZE > obs.x && drone.x < obs.x + OBSTACLE_WIDTH) {
                if (drone.y < obs.topHeight || drone.y + DRONE_SIZE > obs.bottomY) {
                    return true;
                }
            }
        }
        return false;
    }
    
    // Отрисовка фона
    function drawBackground() {
        // Небо с градиентом
        let grad = ctx.createLinearGradient(0, 0, 0, CANVAS_H);
        grad.addColorStop(0, '#0a2f4a');
        grad.addColorStop(1, '#1a6d8a');
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, CANVAS_W, CANVAS_H);
        
        // Облака
        ctx.fillStyle = 'rgba(255,255,240,0.3)';
        ctx.beginPath();
        ctx.ellipse(70, 80, 40, 25, 0, 0, Math.PI*2);
        ctx.ellipse(110, 70, 35, 22, 0, 0, Math.PI*2);
        ctx.ellipse(40, 95, 30, 20, 0, 0, Math.PI*2);
        ctx.fill();
        ctx.beginPath();
        ctx.ellipse(300, 150, 45, 28, 0, 0, Math.PI*2);
        ctx.ellipse(340, 140, 35, 22, 0, 0, Math.PI*2);
        ctx.fill();
        
        // Земля/город внизу
        ctx.fillStyle = '#3a6b3a';
        ctx.fillRect(0, CANVAS_H - 30, CANVAS_W, 30);
        ctx.fillStyle = '#5a8a4a';
        for (let i = 0; i < 12; i++) {
            ctx.fillRect(i*35, CANVAS_H - 45, 18, 25);
        }
    }
    
    // Игровой цикл
    function updateGame() {
        if (!gameRunning) return;
        
        // Гравитация
        drone.velocity += drone.gravity;
        drone.y += drone.velocity;
        
        // Генерация препятствий
        frame++;
        if (frame % 80 === 0) {
            addObstacle();
        }
        
        updateObstacles();
        
        if (checkCollision()) {
            gameOver();
            return;
        }
        
        drawGame();
    }
    
    function drawGame() {
        drawBackground();
        
        // Препятствия
        for (let obs of obstacles) {
            drawObstacle(obs.x, obs.topHeight, obs.bottomY);
        }
        
        drawDrone();
        
        // Счет в центре при старте (опционально)
        if (!gameRunning) {
            ctx.fillStyle = 'white';
            ctx.font = 'bold 28px system-ui';
            ctx.shadowBlur = 0;
            ctx.fillText('GAME OVER', CANVAS_W/2-100, CANVAS_H/2-40);
            ctx.font = '18px system-ui';
            ctx.fillStyle = '#ddd';
            ctx.fillText('Нажми на экран', CANVAS_W/2-85, CANVAS_H/2+20);
        }
    }
    
    // Функция прыжка
    function jump() {
        if (!gameRunning) {
            resetGame();
            return;
        }
        drone.velocity = drone.lift;
        // Визуальный и тактильный отклик
        if (typeof navigator.vibrate === 'function') navigator.vibrate(30);
        // Звук (если поддерживается)
        playBeep();
    }
    
    function playBeep() {
        try {
            let audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            let osc = audioCtx.createOscillator();
            let gain = audioCtx.createGain();
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            osc.frequency.value = 880;
            gain.gain.value = 0.1;
            osc.start();
            gain.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + 0.3);
            osc.stop(audioCtx.currentTime + 0.3);
        } catch(e) { /* звук не критичен */ }
    }
    
    function gameOver() {
        gameRunning = false;
        if (score > bestScore) {
            bestScore = score;
            localStorage.setItem('drone_best', bestScore);
            bestSpan.textContent = bestScore;
        }
        if (typeof navigator.vibrate === 'function') navigator.vibrate(200);
    }
    
    function resetGame() {
        drone.y = CANVAS_H / 2;
        drone.velocity = 0;
        score = 0;
        scoreSpan.textContent = '0';
        obstacles = [];
        frame = 0;
        gameRunning = true;
        drawGame();
    }
    
    // Управление
    function handleTap(e) {
        e.preventDefault();
        jump();
    }
    
    canvas.addEventListener('click', handleTap);
    canvas.addEventListener('touchstart', handleTap, { passive: false });
    
    // Клавиатура (пробел)
    document.addEventListener('keydown', (e) => {
        if (e.code === 'Space') {
            e.preventDefault();
            jump();
        }
    });
    
    // Запуск игры
    function gameLoop() {
        updateGame();
        requestAnimationFrame(gameLoop);
    }
    
    // Инициализация
    addObstacle();
    gameLoop();
    drawGame();
    
    // Для перезапуска через кастомную кнопку в MAX (если понадобится)
    window.resetDroneGame = resetGame;
</script>
</body>
</html>
